{
  "build": {
    "dockerfile": "Dockerfile"
  },
  "onCreateCommand": "chmod +x .github/scripts/setup/init.sh && .github/scripts/setup/init.sh && chmod -x .github/scripts/setup/init.sh && sleep 3",
  "postCreateCommand": "killall -u $DEVELOPER",
  "remoteEnv": {
    "DEVELOPER": "${localEnv:DEVELOPER}",
    "NO_REPLY_EMAIL": "${localEnv:NO_REPLY_EMAIL}"
  },
  "waitFor": "onCreateCommand",
  "runArgs": ["--env-file", ".devcontainer/.env"]
}
